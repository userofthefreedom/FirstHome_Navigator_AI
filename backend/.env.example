DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=true

# Public data portal LH API service key
DATA_GO_KR_SERVICE_KEY=

# Financial Supervisory Service financial product API key
FINLIFE_API_KEY=

# Youth policy API key
YOUTH_POLICY_API_KEY=

# Fixture supplement is only a demo safety net when real active ownership notices are too few by region.
FIRSTHOME_ENABLE_FIXTURE_SUPPLEMENT=true
FIRSTHOME_MIN_ACTIVE_SERVICE_NOTICES_PER_REGION=5

# AI provider
# template: no external LLM call, rule-based PDF extraction and template chat fallback
# openai: OpenAI-compatible Chat Completions API
# local: OpenAI-compatible local LLM endpoint
AI_PROVIDER=template
AI_MODEL=gpt-4o-mini
AI_ENABLE_LLM_EXTRACTION=false
AI_ENABLE_LLM_CHAT=false
AI_REQUEST_TIMEOUT=30

# Required only when AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_CHAT_PATH=/chat/completions

# Required only when AI_PROVIDER=local
LOCAL_LLM_ENDPOINT=
