DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=true

# 공공데이터포털 청약홈/LH API 서비스 키
DATA_GO_KR_SERVICE_KEY=

# 금융감독원 금융상품통합비교공시 API 키
FINLIFE_API_KEY=

# 온통청년 Open API 키가 필요한 경우 사용
YOUTH_POLICY_API_KEY=

# AI provider 설정
# template: API 키 없이 고정 템플릿 응답 사용
# openai: OpenAI 호환 Chat Completions 호출 사용
# local: LOCAL_LLM_ENDPOINT로 OpenAI 호환 Chat Completions 호출 사용
AI_PROVIDER=template
AI_MODEL=gpt-4o-mini
AI_ENABLE_LLM_EXTRACTION=false
AI_ENABLE_LLM_CHAT=false
AI_REQUEST_TIMEOUT=30

# AI_PROVIDER=openai일 때 사용
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_CHAT_PATH=/chat/completions

# AI_PROVIDER=local일 때 사용
LOCAL_LLM_ENDPOINT=
