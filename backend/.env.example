DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=
CORS_ALLOWED_ORIGINS=
CSRF_TRUSTED_ORIGINS=
CORS_ALLOW_ALL_ORIGINS=false

# Cookie settings
# Local HTTP development can keep the defaults below.
# Local/ngrok development uses the Vite dev-server proxy.
# Keep frontend VITE_API_BASE_URL=/api and expose only the frontend with ngrok.
# The local defaults below are recommended for this flow.
SESSION_COOKIE_SAMESITE=Lax
SESSION_COOKIE_SECURE=false
CSRF_COOKIE_SAMESITE=Lax
CSRF_COOKIE_SECURE=false

# Public data portal LH API service key
DATA_GO_KR_SERVICE_KEY=

# Financial Supervisory Service financial product API key
FINLIFE_API_KEY=

# Youth policy API key
YOUTH_POLICY_API_KEY=

# Kakao Local REST API key, used only when geocoding notice locations
KAKAO_REST_API_KEY=

# Fixture supplement is only a demo safety net when real active ownership notices are too few by region.
FIRSTHOME_ENABLE_FIXTURE_SUPPLEMENT=true
FIRSTHOME_MIN_ACTIVE_SERVICE_NOTICES_PER_REGION=5

# AI provider
# openai: OpenAI Chat Completions API
# template: no external LLM call, rule-based PDF extraction and template fallback
AI_PROVIDER=openai
AI_MODEL=gpt-4o-mini
AI_ENABLE_LLM_EXTRACTION=true
AI_ENABLE_LLM_CHAT=true
AI_REQUEST_TIMEOUT=30

# Required only when AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_CHAT_PATH=/chat/completions
